# URI de conexão com o MongoDB Atlas (substitua com as suas credenciais)
MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/<banco>

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=seu_jwt_secret_aqui

# Porta em que a API irá rodar
PORT=4000

# URL do front-end (para configuração do CORS)
FRONTEND_URL=http://localhost:3000
